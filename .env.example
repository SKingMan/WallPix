# ============================================================
# WallPix 环境变量
# 复制为 .env: cp .env.example .env
# ============================================================

# 前端 PB 连接地址：用相对路径 / （同源，容器内反代）
VITE_POCKETBASE_URL=/

# Web 服务端口（主机端口，80 常被占用，默认 18082）
WEB_PORT=18082

# 宿主机 PB 端口（容器内反代目标）
POCKETBASE_PORT=8090

# 时区
TZ=Asia/Shanghai

# ============================================================
# 部署清单
# ============================================================
# 1. 宿主机 PB 监听 0.0.0.0:8090（不能只 127.0.0.1）
# 2. 云安全组开放 WEB_PORT（默认 18082）
# 3. PB 8090 端口可不开（容器走内网访问）
